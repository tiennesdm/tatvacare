# Required environment for docker compose. Copy to `.env` and fill in.
#
# IMPORTANT: never commit `.env`. It's listed in .gitignore. Use a
# placeholder here so the file exists but doesn't leak dev secrets.

# Shared secret for Node ↔ Python AI service. MUST be at least 32 chars.
AI_SERVICE_KEY=replace-with-a-32-char-random-string-please

# Cookie session signing secret. MUST be at least 32 chars.
SESSION_COOKIE_SECRET=replace-with-a-different-32-char-random-string

# Optional — only needed if you enable the redis service:
# REDIS_URL=redis://redis:6379
